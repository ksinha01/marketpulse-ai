# MarketPulse worker config.
#
# Copy this file to ".env.production" (or ".env") in this same "worker/"
# folder on the machine that runs the worker, and fill in real values.
# The worker (app/worker.py) loads this file automatically on startup.
#
# NOTE ON AUTH: the worker talks to Orchestrator via the `uip` CLI
# (see app/asset_client.py), not raw HTTP calls with these credentials
# directly. That means an active `uip login` session must already exist
# before running the worker locally:
#
#   uip login --client-id <ID> --client-secret <SECRET> --tenant <TENANT> --scope "OR.Assets"
#
# (In GitHub Actions, the workflow does this login step for you using the
# UIPATH_CLIENT_ID / UIPATH_CLIENT_SECRET / UIPATH_TENANT_NAME secrets —
# those don't need to be in this file, only used for local testing.)
#
# SECURITY: this file contains live secrets once filled in.
#   - Do NOT commit it to git (it's already covered by a .gitignore entry).
#   - Restrict OS-level file permissions so only you can read it
#     (`chmod 600` on Linux/macOS).

# The MarketPulseSnapshot asset's UUID key (not its name) and the
# Orchestrator folder it lives in — e.g. "Shared".
ASSET_KEY=
ASSET_FOLDER_PATH=Shared

# --- Third-party API keys used by the existing service modules ---
OPENAI_API_KEY=
NEWS_API_KEY=
GNEWS_API_KEY=
FINNHUB_API_KEY=

# --- Dhan (used by dhan_options.py for options-chain data only; no orders are placed) ---
# Rotate these before use — they were exposed in the original upload.
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
